# Python cache and bytecode
__pycache__/
*.py[cod]
*.pyo

# Virtual environments and local tooling
.venv/
venv/
.env
.idea/
.vscode/

# OS junk
.DS_Store
Thumbs.db

# Experiment outputs and large artifacts
runs/
paper_artifacts/

# Checkpoints and logs
*.pt
*.ckpt
*.log

# Plots/data generated by scripts (keep figures/ images tracked)
figures/**/*.csv

# Jupyter/IPython checkpoints
.ipynb_checkpoints/

# Data directory (keep manifest tracked)
data/*
!data/manifest.csv

# LaTeX build artifacts (keep .tex/.bib tracked)
*.aux
*.bbl
*.bcf
*.blg
*.brf
*.fdb_latexmk
*.fls
*.lof
*.log
*.lot
*.nav
*.out
*.run.xml
*.snm
*.synctex.gz
*.toc
*.vrb
*.xdv
*.dvi
*.ps

# LaTeX editor/backup files
*.synctex(busy)
*~
*.bak
*.backup
*.orig

# LaTeX minted cache
_minted-*/
